@{
    ViewBag.Title = "Contacto";
}
<div class="container mt-5">

    <!-- Encabezado -->
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">📞 @ViewBag.Title</h2
    </div>

    <div class="row g-4">

        <!-- Información de contacto -->
        <div class="col-md-6">
            <div class="card shadow-lg border-0 h-100">
                <div class="card-body p-4">

                    <h4 class="fw-semibold mb-3">📍 Dirección</h4>
                    <p class="text-muted">
                        One Microsoft Way<br />
                        Redmond, WA 98052-6399
                    </p>

                    <hr />

                    <h4 class="fw-semibold mb-3">📱 Teléfono</h4>
                    <p class="text-muted">
                        <abbr title="Phone">P:</abbr> 425.555.0100
                    </p>

                </div>
            </div>
        </div>

        <!-- Correos -->
        <div class="col-md-6">
            <div class="card shadow-lg border-0 h-100">
                <div class="card-body p-4">

                    <h4 class="fw-semibold mb-3">✉️ Correos</h4>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">
                            <strong>Soporte:</strong><br />
                            <a href="mailto:Support@example.com" class="text-decoration-none">
                                Support@example.com
                            </a>
                        </li>

                        <li class="list-group-item">
                            <strong>Marketing:</strong><br />
                            <a href="mailto:Marketing@example.com" class="text-decoration-none">
                                Marketing@example.com
                            </a>
                        </li>
                    </ul>

                </div>
            </div>
        </div>

    </div>

  
    </div>

</div>