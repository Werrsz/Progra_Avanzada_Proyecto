@{
    ViewBag.Title = "Sobre nosotros";
}

<div class="container mt-5">

    <!-- Encabezado -->
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">📚 @ViewBag.Title</h2>
       
    </div>

    <!-- Card principal -->
    <div class="card shadow-lg border-0">
        <div class="card-body p-5">

            <h4 class="fw-semibold mb-3">Nuestra Historia</h4>
            <p class="text-muted">
                Bienvenido a nuestra librería, un espacio dedicado a los amantes de los libros,
                la creatividad y el aprendizaje. Aquí encontrarás una gran variedad de productos
                cuidadosamente seleccionados para inspirarte cada día.
            </p>

            <hr />

            <h4 class="fw-semibold mb-3">¿Qué ofrecemos?</h4>
            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item">📖 Libros de diferentes géneros</li>
                <li class="list-group-item">🖊️ Artículos de papelería</li>
                <li class="list-group-item">🎨 Productos creativos y escolares</li>
                <li class="list-group-item">🎁 Regalos especiales</li>
            </ul>

            <hr />

            <h4 class="fw-semibold mb-3">Nuestra Misión</h4>
            <p class="text-muted">
                Fomentar la lectura, la educación y la creatividad ofreciendo productos de calidad
                en un ambiente accesible y agradable para todos.
            </p>

            <!-- Botón -->
            <div class="text-center mt-4">
                <a href="/" class="btn btn-primary btn-lg">
                     Volver al Inicio
                </a>
            </div>

        </div>
    </div>

</div>