<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Librería</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

</head>
<body>

    ```
    <!-- NAVBAR MEJORADO -->
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow">
        <div class="container">
            @Html.ActionLink(" Librería y bazar", "Index", "Home", new { area = "" }, new { @class = "navbar-brand fw-bold" })

            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        @Html.ActionLink("Inicio", "Index", "Home", new { area = "" }, new { @class = "nav-link active" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Libros", "Index", "Producto", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Acerca de", "About", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Contacto", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Reseñas", "resenas", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                </ul>
            </div>
        </div>
    </nav>

  
    <div class="bg-dark text-white text-center py-5">
        <div class="container">
            <h1 class="display-4 fw-bold">Descubre tu próximo libro</h1>
            <p class="lead">Explora miles de historias, autores y géneros</p>
            <a href="/Producto" class="btn btn-warning btn-lg">Ver catálogo</a>
        </div>
    </div>

    <!-- CONTENIDO -->
    <div class="container body-content mt-4">

        @RenderBody()

       

        <hr />

        <!-- FOOTER MEJORADO -->
        <footer class="text-center py-3">
            <p class="mb-0">&copy; @DateTime.Now.Year - Librería Online | Todos los derechos reservados</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    @RenderSection("scripts", required: false)
    ```

</body>
</html>
